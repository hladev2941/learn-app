# Normalize line endings
* text=auto eol=lf

# Java / XML
*.java text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.properties text eol=lf

# Web
*.ts text eol=lf
*.html text eol=lf
*.scss text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf

# Shell / Docker
Dockerfile text eol=lf
*.sh text eol=lf

# Binary
*.jar binary
*.png binary
*.jpg binary
*.ico binary
